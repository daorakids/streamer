[Unit]
Description=Daora Kids Sync Service
After=network-online.target mnt-videos.mount
Wants=network-online.target
Requires=mnt-videos.mount

[Service]
Type=oneshot
User=stream
Nice=19
IOSchedulingClass=idle
# -P /mnt/videos garante o pendrive. Removemos -nd para manter as subpastas pt/en/es
ExecStart=/usr/bin/wget --user=stream --password=stream -c -N -r -np -nH --cut-dirs=2 --modify-window=2 -A mp4 --tries=10 -P /mnt/videos https://daorakids.com.br/util/stream/
